---
const { active = 'home' } = Astro.props;
---
<header class="relative z-40 px-6 md:px-12 lg:px-16 pt-8">
  <div class="flex items-center justify-between">
    <a href="/" class="group inline-flex items-center gap-3">
      <span class="relative inline-flex h-8 w-8 items-center justify-center rounded-full border border-current/30">
        <span class="serif text-base leading-none">M</span>
        <span class="absolute -right-0.5 -top-0.5 h-1.5 w-1.5 rounded-full bg-copper"></span>
      </span>
      <span class="serif text-xl tracking-tight">Meridian</span>
    </a>

    <nav class="hidden md:flex items-center gap-10 text-sm">
      <a href="/" class={`transition-opacity hover:opacity-100 ${active === 'home' ? 'opacity-100' : 'opacity-60'}`}>Waitlist</a>
      <a href="/about" class={`transition-opacity hover:opacity-100 ${active === 'about' ? 'opacity-100' : 'opacity-60'}`}>Our Story</a>
      <a href="/#ritual" class="opacity-60 transition-opacity hover:opacity-100">The Ritual</a>
      <a href="/#origin" class="opacity-60 transition-opacity hover:opacity-100">Origin</a>
    </nav>

    <div class="flex items-center gap-3">
      <button data-theme-toggle aria-label="Toggle theme"
              class="inline-flex h-9 w-9 items-center justify-center rounded-full border border-current/20 hover:border-current/60 transition">
        <svg class="h-4 w-4 dark:hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79Z" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        <svg class="h-4 w-4 hidden dark:block" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <circle cx="12" cy="12" r="4" />
          <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41" stroke-linecap="round"/>
        </svg>
      </button>
      <a href="/#waitlist" class="hidden sm:inline-flex items-center gap-2 rounded-full bg-espresso px-4 py-2 text-sm text-cream dark:bg-cream dark:text-ink transition hover:bg-copper dark:hover:bg-copper">
        Join Waitlist
        <span aria-hidden>→</span>
      </a>
    </div>
  </div>
</header>
