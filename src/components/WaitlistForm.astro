---
const { variant = 'light' } = Astro.props;
---
<form
  method="POST"
  action="/api/subscribe"
  class="group flex flex-col sm:flex-row w-full max-w-xl gap-3 sm:gap-0"
  data-waitlist
>
  <label class="sr-only" for="waitlist-email">Email address</label>
  <input
    type="email"
    name="email"
    id="waitlist-email"
    required
    autocomplete="email"
    placeholder="your@email.com"
    class={`flex-1 rounded-full sm:rounded-r-none border ${variant === 'dark' ? 'border-cream/20 bg-transparent text-cream placeholder:text-cream/40 focus:border-copper' : 'border-espresso/20 bg-cream/60 text-espresso placeholder:text-espresso/40 focus:border-copper'} px-5 py-3.5 text-sm outline-none transition focus:ring-0`}
  />
  <button
    type="submit"
    class="inline-flex items-center justify-center gap-2 rounded-full sm:rounded-l-none bg-espresso px-6 py-3.5 text-sm text-cream transition hover:bg-copper dark:bg-cream dark:text-ink dark:hover:bg-copper dark:hover:text-cream"
  >
    <span class="whitespace-nowrap">Join the Waitlist</span>
    <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75">
      <path d="M5 12h14M13 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </button>
</form>
<p data-waitlist-msg class="mt-3 text-xs uppercase tracking-widest opacity-60" aria-live="polite"></p>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    document.querySelectorAll('form[data-waitlist]').forEach((form) => {
      const msg = form.parentElement?.querySelector('[data-waitlist-msg]') || form.querySelector('[data-waitlist-msg]');
      form.addEventListener('submit', async (ev) => {
        ev.preventDefault();
        const data = new FormData(form);
        const email = (data.get('email') || '').toString().trim();
        if (!email) return;
        if (msg) msg.textContent = 'Securing your seat…';
        try {
          const res = await fetch('/api/subscribe', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ email }),
          });
          const json = await res.json().catch(() => ({}));
          if (res.ok) {
            window.location.href = '/thanks';
          } else {
            if (msg) msg.textContent = json.error || 'Something went wrong. Try again?';
          }
        } catch (e) {
          if (msg) msg.textContent = 'Network hiccup — please retry.';
        }
      });
    });
  });
</script>
